  "spec_reference": "SCORING_LOGIC_v3.0.md §8",
  "normalization_rules": {
    "pct_to_5": {
      "formula": "1 + (raw / 100) * 4",
      "raw_range": [
        0,
        100
      ]
    },
    "index_to_5": {
      "formula": "1 + raw * 4",
      "raw_range": [
        0,
        1
      ]
    },
    "custom": {
      "formula": "1 + ((raw - min) / (max - min)) * 4",
      "raw_range": "defined per indicator"
    }
  },
